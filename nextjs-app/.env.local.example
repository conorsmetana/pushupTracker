# Database - Local Development with SQLite (default)
# The dev.db file will be created automatically on first prisma migrate command
DATABASE_URL="file:./prisma/dev.db"

# NextAuth - Local Development
# Generate a secure secret in production: openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node prisma/generate-schema.js && prisma generate && prisma db push && next build",
    "postinstall": "node prisma/generate-schema.js && prisma generate",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "node prisma/generate-schema.js && prisma generate",
    "prisma:migrate": "node prisma/generate-schema.js && prisma migrate dev",
    "prisma:deploy": "node prisma/generate-schema.js && prisma migrate deploy",
    "prisma:studio": "node prisma/generate-schema.js && prisma studio",
    "prisma:seed": "node prisma/generate-schema.js && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^3.0.3",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.9.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
